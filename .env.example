# GroomX v6 - Environment Variables
# Copy this file to .env and fill in your values

# Flask
SECRET_KEY=your-super-secret-key-change-this
DEBUG=True

# MongoDB
# Local:
MONGO_URI=mongodb://localhost:27017/groomx_db
# Atlas (cloud):
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/groomx_db

# JWT
JWT_SECRET=your-jwt-secret-change-this

# Anthropic (for AI face analysis in backend)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# CORS (use * for dev, restrict in production)
CORS_ORIGINS=*
